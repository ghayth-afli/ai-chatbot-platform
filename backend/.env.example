# Backend Environment Variables Example
# Copy this file to .env and fill in your actual values

# ===========================
# DJANGO SETTINGS
# ===========================

# Django debug mode (set to False in production)
DEBUG=True

# Secret key for Django (generate a new one in production)
# Must be at least 32 bytes for JWT/SHA256 security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ===========================
# DATABASE
# ===========================

# SQLite (default for development)
# DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/chatbot_db

# ===========================
# EMAIL SERVICE
# ===========================

# Email provider (Gmail, SendGrid, AWS SES, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# For Gmail: Generate app-specific password at https://myaccount.google.com/apppasswords
# For SendGrid: Use "apikey" as username and API key as password
# For AWS SES: Use SMTP credentials from AWS console

# ===========================
# GOOGLE OAUTH
# ===========================

# Get credentials from: https://console.cloud.google.com/
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Redirect URI configured in Google Cloud Console:
# http://localhost:3000/auth/callback (development)
# https://yourdomain.com/auth/callback (production)

# ===========================
# JWT & AUTHENTICATION
# ===========================

# JWT Secret (generate a new one, different from DJANGO SECRET_KEY)
JWT_SECRET_KEY=your-jwt-secret-key-different-from-above

JWT_ALGORITHM=HS256

# Token lifetimes (in seconds)
ACCESS_TOKEN_LIFETIME=900       # 15 minutes
REFRESH_TOKEN_LIFETIME=604800   # 7 days

# Cookie settings
AUTH_COOKIE_SECURE=False        # Set to True in production (requires HTTPS)
AUTH_COOKIE_HTTP_ONLY=True
AUTH_COOKIE_SAMESITE=Lax

# ===========================
# RATE LIMITING
# ===========================

# Format: "number_of_requests/time_period"
# Examples: "5/15min", "100/1h", "1000/1d"

RATE_LIMIT_LOGIN=5/15min        # 5 login attempts per 15 minutes per IP
RATE_LIMIT_CODE=3/60min         # 3 code requests per 60 minutes per email

# ===========================
# CACHE (for rate limiting)
# ===========================

# Use Redis in production for distributed rate limiting
# CACHE_URL=redis://localhost:6379/0

# In-memory cache for development
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache

# ===========================
# CORS SETTINGS
# ===========================

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ===========================
# SECURITY SETTINGS
# ===========================

# HTTPS enforcement (set to True in production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# HSTS (HTTP Strict Transport Security) - only set in production
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# Content Security Policy- CSP_DEFAULT_SRC='self'
# CSP_SCRIPT_SRC='self' 'unsafe-inline'
# CSP_STYLE_SRC='self' 'unsafe-inline'

# ===========================
# LOGGING
# ===========================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/app.log

# ===========================
# SENTRY (Error Tracking, Production Only)
# ===========================

# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ===========================
# API SETTINGS
# ===========================

# API version
API_VERSION=v1

# API timeout (seconds)
API_TIMEOUT=30

# ===========================
# NOTIFICATION SETTINGS (OPTIONAL)
# ===========================

# Slack webhook for error alerts (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ===========================
# DEVELOPMENT SETTINGS (DEVELOPMENT ONLY)
# ===========================

# Enable debug toolbar (development only)
DEBUG_TOOLBAR_ENABLED=False

# Allow cross-origin requests without authorization (dev only - NEVER in production)
# ALLOW_UNSAFE_CORS=False
